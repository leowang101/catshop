# ==== 应用 ====
PORT=3020
NODE_ENV=production

# ==== 数据库（商城独立 RDS） ====
DB_HOST=your_rds_host
DB_PORT=3306
DB_USER=catshop
DB_PASS=your_db_password
DB_NAME=catshop

# ==== 管理后台认证 ====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
ADMIN_TOKEN_SECRET=your_random_admin_token_secret

# ==== AI（DashScope / Qwen） ====
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
QWEN_TEXT_MODEL=qwen-plus
QWEN_VL_MODEL=qwen-vl-plus

# ==== 合作方 API（连接主站试用码服务） ====
PARTNER_API_SECRET=your_partner_api_secret
PARTNER_API_BASE_URL=https://aidoucang.cn

# ==== CORS ====
# CORS_ORIGINS=https://shopping.aidoucang.cn,https://admin-shopping.aidoucang.cn
